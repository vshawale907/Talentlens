{
  "$schema": "https://railway.app/schemas/config-v1.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000} --workers 2",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10
  }
}
