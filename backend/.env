NODE_ENV=development
PORT=5000

# MongoDB - local service running on default port
MONGO_URI=mongodb://localhost:27017/talentlens

# Redis - local service running on default port
REDIS_URL=redis://localhost:6379

# JWT - must be at least 32 characters
JWT_SECRET=talentlens-super-secret-jwt-key-2024-dev
JWT_REFRESH_SECRET=talentlens-refresh-secret-jwt-key-2024-dev
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI Keys - add your Gemini key (free) or OpenAI key
# Get Gemini free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq - fast free LLM (Llama 3.3) - https://console.groq.com
GROQ_API_KEY=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

# OpenAI (optional, Gemini is used first if GEMINI_API_KEY is set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Python NLP microservice (runs on port 8000)
AI_SERVICE_URL=http://localhost:8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# Admin seed account
ADMIN_EMAIL=admin@talentlens.com

# Email / SMTP Configuration (for password reset emails)
# For Gmail: use your Gmail address + an "App Password" (NOT your real password)
# Create App Password at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vaibhavhawale9075@gmail.com
SMTP_PASS=eigecxymqwfhmzhm

# Stripe (optional - leave blank for local dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# AWS S3 - File Storage (add your bucket credentials when ready)
# Get started free at: https://aws.amazon.com/ or use Cloudflare R2 (free 10GB)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# For Cloudflare R2 or MinIO: uncomment and set endpoint
# AWS_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Qdrant Vector DB - Semantic Job Matching
# Option 1: Run locally with Docker:  docker run -p 6333:6333 qdrant/qdrant
# Option 2: Get free cloud at: https://cloud.qdrant.io
QDRANT_URL=https://a20d93d0-29fb-4662-9b9a-1526472d8175.sa-east-1-0.aws.cloud.qdrant.io
